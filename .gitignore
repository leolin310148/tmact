.cache/
.tmact/
.agent-inbox/
tmact.agents.yaml
agents.yaml
bin/

# Machine-specific agent skills. These may contain local hostnames, paths, and
# deployment policy and must never be committed.
.agents/skills/local-*/
.claude/skills/local-*/
.codex/skills/local-*/

# Web UI build output — generated by `make web` (Vite), NOT committed.
# The .gitkeep keeps the directory present so go:embed compiles on a fresh
# clone before the frontend is built.
internal/web/static/*
!internal/web/static/.gitkeep
internal/web/frontend/node_modules/
